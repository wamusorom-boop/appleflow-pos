# AppleFlow POS - Environment Configuration
# Copy this file to .env and update the values

# ============================================
# REQUIRED SETTINGS
# ============================================

# Database connection string
# Format: postgresql://user:password@host:port/database
DATABASE_URL="postgresql://postgres:password@localhost:5432/appleflow_pos"

# JWT Secrets - Generate strong random strings for production
# Use: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-this-in-production"

# ============================================
# OPTIONAL SETTINGS
# ============================================

# Environment (development, production, test)
NODE_ENV="development"

# Server port
PORT="3000"

# JWT Token expiration
JWT_EXPIRY="8h"
JWT_REFRESH_EXPIRY="7d"

# Bcrypt rounds for password hashing (higher = more secure but slower)
BCRYPT_ROUNDS="12"

# CORS origins (comma-separated)
CORS_ORIGINS="http://localhost:3000,http://localhost:5173"

# ============================================
# PRODUCTION SETTINGS (Render/Railway/etc)
# ============================================

# In production, set these via your hosting platform's environment variables UI
# DO NOT commit production secrets to git!
