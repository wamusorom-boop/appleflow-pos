// ============================================
// M-PESA INTEGRATION
// ============================================

model MpesaTransaction {
  id                String              @id @default(uuid())
  
  // STK Push fields
  merchantRequestId String?             @unique
  checkoutRequestId String?             @unique
  
  // C2B fields
  transactionId     String?             @unique
  transactionType   String?
  
  // Transaction details
  phoneNumber       String
  amount            Decimal             @db.Decimal(12, 2)
  accountReference  String?
  description       String?
  
  // Response fields
  mpesaReceiptNumber String?
  resultCode        String?
  resultDesc        String?
  
  // Status with state machine
  status            MpesaStatus         @default(PENDING)
  
  // Idempotency
  idempotencyKey    String?             @unique
  
  // Retry tracking
  retryCount        Int                 @default(0)
  maxRetries        Int                 @default(3)
  lastRetryAt       DateTime?
  
  // Signature validation
  callbackSignature String?
  signatureValid    Boolean?
  
  // Customer info (from C2B)
  firstName         String?
  middleName        String?
  lastName          String?
  
  // Sale link
  saleId            String?
  
  // Reconciliation
  reconciledAt      DateTime?
  reconciliationId  String?
  
  // Timestamps
  transactionDate   DateTime?
  callbackReceivedAt DateTime?
  completedAt       DateTime?
  failedAt          DateTime?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  
  @@index([checkoutRequestId])
  @@index([mpesaReceiptNumber])
  @@index([status])
  @@index([idempotencyKey])
  @@index([createdAt])
  @@index([reconciledAt])
  @@map("mpesa_transactions")
}

enum MpesaStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
  REFUNDED
}

