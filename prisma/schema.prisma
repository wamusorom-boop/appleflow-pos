// AppleFlow POS Database Schema - ULTIMATE EDITION
// Production-ready PostgreSQL schema with ALL retail features

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// LICENSE KEY SYSTEM - CREATOR PROTECTION
// ============================================

model LicenseKey {
  id            String        @id @default(uuid())
  key           String        @unique
  name          String        // License holder name
  email         String        // License holder email
  phone         String?       // License holder phone
  
  // License tiers
  tier          LicenseTier   @default(BASIC)
  
  // Status
  status        LicenseStatus @default(ACTIVE)
  
  // Activation tracking
  activatedAt   DateTime?
  expiresAt     DateTime?
  lastVerifiedAt DateTime?
  
  // Device/Instance tracking
  maxDevices    Int           @default(1)
  deviceCount   Int           @default(0)
  devices       LicenseDevice[]
  
  // Features enabled
  features      Json          @default("{}")
  
  // Metadata
  notes         String?
  createdBy     String        // Creator/admin who issued this
  
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  
  @@index([key])
  @@index([status])
  @@index([email])
  @@index([expiresAt])
  @@map("license_keys")
}

model LicenseDevice {
  id            String   @id @default(uuid())
  licenseId     String
  license       LicenseKey @relation(fields: [licenseId], references: [id], onDelete: Cascade)
  
  deviceId      String   @unique // Hardware ID or generated UUID
  deviceName    String?
  deviceType    String?  // POS_TERMINAL, MOBILE, TABLET
  
  ipAddress     String?
  lastSeenAt    DateTime @default(now())
  
  createdAt     DateTime @default(now())
  
  @@index([licenseId])
  @@index([deviceId])
  @@map("license_devices")
}

enum LicenseTier {
  TRIAL
  BASIC
  STANDARD
  PROFESSIONAL
  ENTERPRISE
}

enum LicenseStatus {
  PENDING
  ACTIVE
  SUSPENDED
  EXPIRED
  REVOKED
}

// ============================================
// USER MANAGEMENT - EXPANDED
// ============================================

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  pinHash   String   // bcrypt hashed PIN
  role      UserRole @default(CASHIER)
  isActive  Boolean  @default(true)
  lastLoginAt DateTime?
  
  // Profile
  avatar    String?
  phone     String?
  address   String?
  
  // Permissions override
  permissions Json?
  
  // Theme preference
  themePreference String @default("system")
  accentColor     String @default("#3b82f6")
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  sessions        Session[]
  shifts          Shift[]
  sales           Sale[]
  auditLogs       AuditLog[]
  createdByMe     PurchaseOrder[] @relation("CreatedBy")
  stockAdjustments StockAdjustment[]
  transfersCreated StockTransfer[] @relation("TransferCreatedBy")
  transfersReceived StockTransfer[] @relation("TransferReceivedBy")
  zReports        ZReport[]
  commissions     StaffCommission[]
  timeEntries     TimeEntry[]
  activityLogs    UserActivityLog[]
  
  @@index([email])
  @@index([role])
  @@index([isActive])
  @@map("users")
}

model Session {
  id           String   @id @default(uuid())
  userId       String
  token        String   @unique
  refreshToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  @@index([userId])
  @@index([token])
  @@index([refreshToken])
  @@map("sessions")
}

model UserActivityLog {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  action      String   // LOGIN, LOGOUT, SALE_CREATED, etc.
  description String?
  
  ipAddress   String?
  userAgent   String?
  
  metadata    Json?    // Additional context
  
  createdAt   DateTime @default(now())
  
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("user_activity_logs")
}

enum UserRole {
  ADMIN
  MANAGER
  SUPERVISOR
  CASHIER
  INVENTORY_CLERK
  ACCOUNTANT
  STAFF
}

// ============================================
// PRODUCT & INVENTORY - COMPLETE
// ============================================

model Category {
  id          String   @id @default(uuid())
  name        String
  description String?
  color       String   @default("#3b82f6")
  icon        String?  // Lucide icon name
  imageUrl    String?
  
  // Hierarchy
  parentId    String?
  parent      Category? @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  products    Product[]
  
  @@index([parentId])
  @@index([isActive])
  @@map("categories")
}

model Product {
  id          String      @id @default(uuid())
  sku         String      @unique
  name        String
  description String?
  barcode     String?     @unique
  qrCode      String?     @unique
  
  // Pricing - Multiple price levels
  costPrice           Decimal  @db.Decimal(12, 2)
  sellingPrice        Decimal  @db.Decimal(12, 2)
  wholesalePrice      Decimal? @db.Decimal(12, 2)
  memberPrice         Decimal? @db.Decimal(12, 2) // Loyalty member price
  bulkPrice           Decimal? @db.Decimal(12, 2) // Bulk discount price
  
  // Tax
  taxRate             Decimal  @default(0.00) @db.Decimal(5, 2)
  isTaxInclusive      Boolean  @default(false)
  taxClassId          String?
  taxClass            TaxClass? @relation(fields: [taxClassId], references: [id])
  
  // Inventory
  quantity            Int     @default(0)
  minStockLevel       Int     @default(10)
  maxStockLevel       Int?
  reorderPoint        Int     @default(20)
  reorderQuantity     Int     @default(50)
  
  // Product Type
  productType         ProductType @default(STANDARD)
  weightUnit          String?     // kg, g, lb, oz
  
  // Status
  isActive            Boolean @default(true)
  isFeatured          Boolean @default(false)
  allowBackorders     Boolean @default(false)
  trackInventory      Boolean @default(true)
  
  // Physical
  weight              Decimal? @db.Decimal(10, 3)
  dimensions          Json?    // {length, width, height}
  
  // Images
  images              ProductImage[]
  
  // Variants (for size/color variations)
  hasVariants         Boolean @default(false)
  variantAttributes   Json?   // [{name: "Size", values: ["S","M","L"]}]
  variants            ProductVariant[]
  parentId            String?
  parent              Product? @relation("ProductVariants", fields: [parentId], references: [id])
  children            Product[] @relation("ProductVariants")
  
  // Soft delete
  deletedAt           DateTime?
  deletedBy           String?
  
  // Relations
  categoryId          String
  category            Category @relation(fields: [categoryId], references: [id])
  supplierId          String?
  supplier            Supplier? @relation(fields: [supplierId], references: [id])
  brandId             String?
  brand               Brand?    @relation(fields: [brandId], references: [id])
  
  // Timestamps
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  
  // Relations
  saleItems           SaleItem[]
  stockMovements      StockMovement[]
  stockAdjustments    StockAdjustment[]
  transferItems       StockTransferItem[]
  comboItems          ComboItem[]
  
  @@index([sku])
  @@index([barcode])
  @@index([categoryId])
  @@index([isActive])
  @@index([deletedAt])
  @@index([brandId])
  @@map("products")
}

model ProductImage {
  id          String   @id @default(uuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  url         String
  alt         String?
  isPrimary   Boolean  @default(false)
  sortOrder   Int      @default(0)
  
  createdAt   DateTime @default(now())
  
  @@index([productId])
  @@map("product_images")
}

model ProductVariant {
  id          String   @id @default(uuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  
  sku         String   @unique
  barcode     String?  @unique
  
  // Variant attributes
  attributes  Json     // {Size: "Large", Color: "Red"}
  
  // Pricing override
  priceOverride Decimal? @db.Decimal(12, 2)
  
  // Inventory
  quantity    Int      @default(0)
  
  isActive    Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([productId])
  @@index([sku])
  @@map("product_variants")
}

model Brand {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  logoUrl     String?
  website     String?
  
  isActive    Boolean  @default(true)
  
  products    Product[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("brands")
}

enum ProductType {
  STANDARD
  WEIGHTED
  SERIALIZED
  SERVICE
  COMBO
  GIFT_CARD
  SUBSCRIPTION
}

model Supplier {
  id            String   @id @default(uuid())
  name          String
  contactPerson String?
  phone         String
  email         String?
  address       String?
  city          String?
  country       String   @default("Kenya")
  taxId         String?
  paymentTerms  String   @default("Net 30")
  
  // Credit
  creditLimit   Decimal  @default(0) @db.Decimal(12, 2)
  currentBalance Decimal @default(0) @db.Decimal(12, 2)
  
  isActive      Boolean  @default(true)
  
  // Soft delete
  deletedAt     DateTime?
  
  products      Product[]
  purchaseOrders PurchaseOrder[]
  supplierPayments SupplierPayment[]
  
  @@index([deletedAt])
  @@map("suppliers")
}

model SupplierPayment {
  id          String   @id @default(uuid())
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id])
  
  amount      Decimal  @db.Decimal(12, 2)
  method      PaymentMethod
  reference   String?
  notes       String?
  
  createdAt   DateTime @default(now())
  
  @@index([supplierId])
  @@map("supplier_payments")
}

// ============================================
// COMBO/BUNDLE PRODUCTS
// ============================================

model ComboItem {
  id          String   @id @default(uuid())
  comboId     String   // The combo product
  combo       Product  @relation(fields: [comboId], references: [id])
  
  productId   String   // The included product
  quantity    Int      @default(1)
  
  // Optional override
  priceOverride Decimal? @db.Decimal(12, 2)
  
  @@index([comboId])
  @@map("combo_items")
}

// ============================================
// SALES & TRANSACTIONS - COMPLETE
// ============================================

model Sale {
  id              String      @id @default(uuid())
  receiptNumber   String      @unique
  
  // Amounts
  subtotal        Decimal     @db.Decimal(12, 2)
  discountTotal   Decimal     @default(0) @db.Decimal(12, 2)
  taxTotal        Decimal     @default(0) @db.Decimal(12, 2)
  total           Decimal     @db.Decimal(12, 2)
  
  // Status
  status          SaleStatus  @default(COMPLETED)
  
  // Sale Type
  saleType        SaleType    @default(INSTORE)
  
  // Delivery
  deliveryStatus  DeliveryStatus?
  deliveryAddress String?
  deliveryFee     Decimal?    @db.Decimal(12, 2)
  deliveredAt     DateTime?
  
  // Void/Refund info
  voidedAt        DateTime?
  voidedBy        String?
  voidReason      String?
  
  // Refund
  refundAmount    Decimal?    @db.Decimal(12, 2)
  refundReason    String?
  
  // Relations
  items           SaleItem[]
  payments        Payment[]
  
  // User & Shift
  userId          String
  user            User        @relation(fields: [userId], references: [id])
  shiftId         String?
  shift           Shift?      @relation(fields: [shiftId], references: [id])
  
  // Customer
  customerId      String?
  customer        Customer?   @relation(fields: [customerId], references: [id])
  
  // Table (for restaurants)
  tableId         String?
  table           Table?      @relation(fields: [tableId], references: [id])
  
  // Timestamps
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  
  loyaltyHistory  LoyaltyHistory[]
  
  @@index([receiptNumber])
  @@index([createdAt])
  @@index([userId])
  @@index([shiftId])
  @@index([customerId])
  @@index([status])
  @@map("sales")
}

model SaleItem {
  id              String   @id @default(uuid())
  
  saleId          String
  sale            Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  
  productId       String
  product         Product  @relation(fields: [productId], references: [id])
  
  productName     String   // Snapshot at time of sale
  sku             String
  
  quantity        Int
  weight          Decimal? @db.Decimal(10, 3)
  serialNumber    String?
  
  unitPrice       Decimal  @db.Decimal(12, 2)
  discountPercent Decimal  @default(0) @db.Decimal(5, 2)
  discountAmount  Decimal  @default(0) @db.Decimal(12, 2)
  taxAmount       Decimal  @default(0) @db.Decimal(12, 2)
  total           Decimal  @db.Decimal(12, 2)
  
  // For kitchen/restaurant
  kitchenStatus   KitchenStatus @default(PENDING)
  notes           String?
  
  @@index([saleId])
  @@index([productId])
  @@map("sale_items")
}

enum KitchenStatus {
  PENDING
  PREPARING
  READY
  SERVED
  CANCELLED
}

model Payment {
  id          String        @id @default(uuid())
  saleId      String
  sale        Sale          @relation(fields: [saleId], references: [id], onDelete: Cascade)
  
  method      PaymentMethod
  amount      Decimal       @db.Decimal(12, 2)
  
  // M-Pesa specific
  mpesaCode   String?
  mpesaPhone  String?
  
  // Card specific
  cardLast4   String?
  cardType    String?
  
  // Reference
  reference   String?
  
  // Idempotency key for duplicate prevention
  idempotencyKey String?    @unique
  
  // Status for async payments
  status      PaymentStatus @default(PENDING)
  
  // Retry tracking
  retryCount  Int           @default(0)
  lastRetryAt DateTime?
  
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  
  @@index([saleId])
  @@index([method])
  @@index([status])
  @@index([idempotencyKey])
  @@index([createdAt])
  @@map("payments")
}

enum SaleStatus {
  PENDING
  COMPLETED
  VOIDED
  REFUNDED
  LAYAWAY
  QUOTATION
  ORDER
}

enum SaleType {
  INSTORE
  ONLINE
  PHONE
  DELIVERY
  PICKUP
  TABLE_SERVICE
}

enum DeliveryStatus {
  PENDING
  PREPARING
  READY
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  CASH
  MPESA
  CARD
  BANK_TRANSFER
  CHEQUE
  GIFT_CARD
  STORE_CREDIT
  LOYALTY_POINTS
  SPLIT
  CREDIT
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
  REFUNDED
}

// ============================================
// CUSTOMERS - COMPLETE WITH LOYALTY
// ============================================

model Customer {
  id          String   @id @default(uuid())
  name        String
  email       String?
  phone       String?  @unique
  phone2      String?
  address     String?
  city        String?
  country     String   @default("Kenya")
  taxId       String?
  
  // Birthday for promotions
  birthDate   DateTime?
  
  // Loyalty
  loyaltyPoints       Int     @default(0)
  lifetimePoints      Int     @default(0)
  loyaltyTier         String  @default("BRONZE")
  loyaltyCardNumber   String? @unique
  
  totalSpent          Decimal @default(0) @db.Decimal(12, 2)
  totalVisits         Int     @default(0)
  lastVisitAt         DateTime?
  
  // Credit
  creditLimit         Decimal @default(0) @db.Decimal(12, 2)
  currentBalance      Decimal @default(0) @db.Decimal(12, 2)
  
  // Preferences
  preferences         Json?   // {newsletter: true, smsAlerts: false}
  
  isActive            Boolean  @default(true)
  
  // Soft delete
  deletedAt           DateTime?
  
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  
  sales               Sale[]
  loyaltyHistory      LoyaltyHistory[]
  debtorPayments      DebtorPayment[]
  reservations        Reservation[]
  
  @@index([phone])
  @@index([email])
  @@index([loyaltyCardNumber])
  @@index([deletedAt])
  @@map("customers")
}

// ============================================
// RESTAURANT/TABLE MANAGEMENT
// ============================================

model Table {
  id          String   @id @default(uuid())
  number      String   @unique
  name        String?
  capacity    Int      @default(4)
  
  // Location
  sectionId   String?
  section     Section? @relation(fields: [sectionId], references: [id])
  
  // Status
  status      TableStatus @default(AVAILABLE)
  
  // Current occupancy
  currentGuests Int?
  currentSaleId String?
  
  // QR code for self-ordering
  qrCode      String?
  
  isActive    Boolean  @default(true)
  
  sales       Sale[]
  reservations Reservation[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([sectionId])
  @@index([status])
  @@map("tables")
}

model Section {
  id          String   @id @default(uuid())
  name        String
  description String?
  
  tables      Table[]
  
  isActive    Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  
  @@map("sections")
}

model Reservation {
  id          String   @id @default(uuid())
  
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id])
  
  tableId     String?
  table       Table?   @relation(fields: [tableId], references: [id])
  
  // Reservation details
  date        DateTime
  time        String   // "18:30"
  partySize   Int
  
  status      ReservationStatus @default(CONFIRMED)
  
  notes       String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([customerId])
  @@index([date])
  @@index([status])
  @@map("reservations")
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  CLEANING
  OUT_OF_ORDER
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  SEATED
  COMPLETED
  CANCELLED
  NO_SHOW
}

// ============================================
// SHIFTS & CASH MANAGEMENT
// ============================================

model Shift {
  id              String   @id @default(uuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  
  openedAt        DateTime @default(now())
  closedAt        DateTime?
  
  openingCash     Decimal  @db.Decimal(12, 2)
  closingCash     Decimal? @db.Decimal(12, 2)
  expectedCash    Decimal? @db.Decimal(12, 2)
  cashDifference  Decimal? @db.Decimal(12, 2)
  
  // Sales summary
  cashSales       Decimal  @default(0) @db.Decimal(12, 2)
  mpesaSales      Decimal  @default(0) @db.Decimal(12, 2)
  cardSales       Decimal  @default(0) @db.Decimal(12, 2)
  bankSales       Decimal  @default(0) @db.Decimal(12, 2)
  creditSales     Decimal  @default(0) @db.Decimal(12, 2)
  giftCardSales   Decimal  @default(0) @db.Decimal(12, 2)
  loyaltySales    Decimal  @default(0) @db.Decimal(12, 2)
  
  transactionCount Int     @default(0)
  refundTotal     Decimal  @default(0) @db.Decimal(12, 2)
  voidCount       Int      @default(0)
  
  isActive        Boolean  @default(true)
  isClosed        Boolean  @default(false)
  
  sales           Sale[]
  cashMovements   CashMovement[]
  
  @@index([userId])
  @@index([openedAt])
  @@index([isActive])
  @@map("shifts")
}

model CashMovement {
  id          String            @id @default(uuid())
  shiftId     String
  shift       Shift             @relation(fields: [shiftId], references: [id])
  
  type        CashMovementType
  amount      Decimal           @db.Decimal(12, 2)
  reason      String
  
  performedBy String
  createdAt   DateTime          @default(now())
  
  @@index([shiftId])
  @@map("cash_movements")
}

enum CashMovementType {
  PAID_IN
  PAID_OUT
  CASH_DROP
  FLOAT_ADD
  FLOAT_REMOVE
}

// ============================================
// PURCHASE ORDERS
// ============================================

model PurchaseOrder {
  id          String         @id @default(uuid())
  poNumber    String         @unique
  
  supplierId  String
  supplier    Supplier       @relation(fields: [supplierId], references: [id])
  
  status      POStatus       @default(DRAFT)
  
  subtotal    Decimal        @db.Decimal(12, 2)
  taxTotal    Decimal        @db.Decimal(12, 2)
  total       Decimal        @db.Decimal(12, 2)
  
  expectedDate DateTime?
  receivedDate DateTime?
  
  notes       String?
  
  createdBy   String
  creator     User           @relation("CreatedBy", fields: [createdBy], references: [id])
  
  items       PurchaseOrderItem[]
  grns        GoodsReceivedNote[]
  
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  
  @@index([poNumber])
  @@index([status])
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id              String        @id @default(uuid())
  
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  
  productId       String
  productName     String
  sku             String
  
  quantity        Int
  receivedQuantity Int         @default(0)
  unitPrice       Decimal       @db.Decimal(12, 2)
  total           Decimal       @db.Decimal(12, 2)
  
  @@index([purchaseOrderId])
  @@map("purchase_order_items")
}

enum POStatus {
  DRAFT
  SENT
  PARTIAL
  RECEIVED
  CANCELLED
}

// ============================================
// STOCK MANAGEMENT
// ============================================

model StockMovement {
  id          String            @id @default(uuid())
  
  productId   String
  product     Product           @relation(fields: [productId], references: [id])
  
  type        StockMovementType
  quantity    Int
  previousQty Int
  newQty      Int
  
  reason      String?
  reference   String?           // PO number, Sale receipt, etc.
  
  performedBy String
  createdAt   DateTime          @default(now())
  
  @@index([productId])
  @@index([createdAt])
  @@map("stock_movements")
}

enum StockMovementType {
  SALE
  PURCHASE
  ADJUSTMENT
  TRANSFER_IN
  TRANSFER_OUT
  RETURN
  DAMAGE
  EXPIRY
  COUNT
}

// ============================================
// AUDIT & LOGGING
// ============================================

model AuditLog {
  id          String   @id @default(uuid())
  
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  
  action      String
  entityType  String
  entityId    String
  details     String
  
  oldValue    String?
  newValue    String?
  
  ipAddress   String?
  userAgent   String?
  
  createdAt   DateTime @default(now())
  
  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([createdAt])
  @@map("audit_logs")
}

// ============================================
// BUSINESS SETTINGS - EXPANDED
// ============================================

model Business {
  id          String   @id @default(uuid())
  
  name        String
  legalName   String?
  
  address     String
  city        String
  country     String   @default("Kenya")
  
  phone       String
  email       String
  website     String?
  
  taxId       String?
  vatNumber   String?
  
  // Logo
  logoUrl     String?
  faviconUrl  String?
  
  // Receipt settings
  receiptHeader String?
  receiptFooter String?
  receiptShowLogo Boolean @default(true)
  receiptShowTax  Boolean @default(true)
  
  // Currency
  currency    String   @default("KES")
  currencySymbol String @default("KSh")
  
  // Tax Configuration
  enableTax       Boolean @default(false)
  taxRate         Decimal @default(0.00) @db.Decimal(5, 2)
  taxName         String  @default("VAT")
  taxRegistration String?
  
  // Features
  enableLoyalty       Boolean @default(true)
  enableGiftCards     Boolean @default(true)
  enableCreditSales   Boolean @default(false)
