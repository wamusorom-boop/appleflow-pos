# ============================================
# AppleFlow POS - Environment Configuration Template
# Copy this file to .env and fill in your values
# ============================================

# ============================================
# Application
# ============================================
NODE_ENV=production
PORT=3000
API_URL=https://api.yourdomain.com
FRONTEND_URL=https://pos.yourdomain.com

# Comma-separated list of allowed CORS origins
CORS_ORIGINS=https://pos.yourdomain.com,https://admin.yourdomain.com

# ============================================
# Database
# ============================================
DATABASE_URL=postgresql://username:password@localhost:5432/appleflow?schema=public

# For Docker Compose
DB_USER=appleflow
DB_PASSWORD=your_secure_password_here
DB_NAME=appleflow
DB_PORT=5432

# ============================================
# Redis (optional, for caching)
# ============================================
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# ============================================
# JWT Authentication
# ============================================
# Generate with: openssl rand -base64 32
JWT_SECRET=your_jwt_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here

# Token expiration (in seconds)
JWT_ACCESS_EXPIRY=900
JWT_REFRESH_EXPIRY=604800

# ============================================
# M-Pesa Configuration
# ============================================
MPESA_ENVIRONMENT=sandbox
MPESA_SHORT_CODE=174379
MPESA_PASSKEY=your_passkey_here
MPESA_CONSUMER_KEY=your_consumer_key_here
MPESA_CONSUMER_SECRET=your_consumer_secret_here
MPESA_INITIATOR_NAME=testapi
MPESA_INITIATOR_PASSWORD=your_initiator_password_here

# Callback URLs (must be HTTPS in production)
MPESA_CALLBACK_URL=https://api.yourdomain.com/api/mpesa/callback
MPESA_RESULT_URL=https://api.yourdomain.com/api/mpesa/result
MPESA_TIMEOUT_URL=https://api.yourdomain.com/api/mpesa/timeout

# Optional: For callback signature validation
MPESA_CALLBACK_SECRET=your_callback_secret_here

# ============================================
# Tax Configuration (Generic)
# ============================================
ENABLE_TAX=true
DEFAULT_TAX_RATE=16
TAX_NAME=VAT
TAX_REGISTRATION_NUMBER=your_tax_reg_number

# ============================================
# Logging
# ============================================
LOG_LEVEL=info

# ============================================
# Security
# ============================================
# Bcrypt rounds for PIN hashing (higher = more secure but slower)
BCRYPT_ROUNDS=12

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# Email (optional, for notifications)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=AppleFlow POS <noreply@yourdomain.com>

# ============================================
# Backup Configuration
# ============================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=your-backup-bucket
BACKUP_S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
